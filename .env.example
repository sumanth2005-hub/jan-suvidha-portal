# ═══════════════════════════════════════════════════════════
# Jan Suvidha Portal — Environment Configuration
# Copy this to .env and fill in your API keys
# ═══════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────
# 1. GEMINI API KEY (Required for AI features)
#    Get free key: https://aistudio.google.com/apikey
#    Used for: Dynamic questioning, language simplification
#    Without it: System uses static question flow (still works!)
# ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ──────────────────────────────────────────────────────────
# 2. MONGODB (Required — must be running)
#    Default: local MongoDB at localhost:27017
#    For cloud: Use MongoDB Atlas free tier connection string
#    Get free: https://www.mongodb.com/cloud/atlas/register
# ──────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/

# ──────────────────────────────────────────────────────────
# 3. FLASK AI SERVICE URL (auto-started, no config needed)
#    This is the internal Flask microservice URL
# ──────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:5000

# ──────────────────────────────────────────────────────────
# 4. FAST2SMS API KEY (Required for SMS reminders)
#    Get free key: https://www.fast2sms.com/
#    Used for: Sending SMS reminders to eligible citizens
#    Without it: SMS are SIMULATED (logged but not sent)
#    NEVER hardcode this key — always use environment variable
# ──────────────────────────────────────────────────────────
FAST2SMS_API_KEY=your-fast2sms-api-key-here
